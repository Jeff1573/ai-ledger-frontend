# 镜像仓库配置：默认为 GHCR。
IMAGE_REGISTRY=ghcr.io
# 需替换为你的 GitHub 用户名或组织名（小写）。
IMAGE_NAMESPACE=your-github-owner
# 可选 latest / sha 短标签 / 版本标签（例如 v1.0.0）。
IMAGE_TAG=latest

# 对外服务端口（后端容器同时提供 API 与静态页面）。
HTTP_PORT=80
TZ=Asia/Shanghai

# PostgreSQL 配置。
POSTGRES_DB=ai_ledger
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_strong_password

# 后端运行配置。
DATABASE_USE_SSL=false
SESSION_SECRET=replace_with_long_random_secret
COOKIE_NAME=ai_ledger_session
SESSION_TTL_SECONDS=2592000
